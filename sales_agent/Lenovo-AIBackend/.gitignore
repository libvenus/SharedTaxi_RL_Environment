# ----------------------------------------------------------------------------
# Python build / runtime artefacts — never commit
# ----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# ----------------------------------------------------------------------------
# Virtual environments
# ----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/

# ----------------------------------------------------------------------------
# Packaging / distribution
# ----------------------------------------------------------------------------
build/
dist/
*.egg-info/
*.egg
.eggs/
pip-log.txt
pip-delete-this-directory.txt

# ----------------------------------------------------------------------------
# Test / coverage artefacts
# ----------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.cache/
nosetests.xml
coverage.xml
*.cover

# ----------------------------------------------------------------------------
# Type checker / linter caches
# ----------------------------------------------------------------------------
.mypy_cache/
.pyre/
.pytype/
.ruff_cache/

# ----------------------------------------------------------------------------
# IDE / editor
# ----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ----------------------------------------------------------------------------
# Logs / local DB dumps / scratch
# ----------------------------------------------------------------------------
*.log
*.sqlite3
*.db
local_dumps/
scratch/

# ----------------------------------------------------------------------------
# Local Docker / env-specific dependency pins (not shared via repo)
# ----------------------------------------------------------------------------
Dockerfile
.dockerignore
requirements-dev.txt
requirements-prod.txt
