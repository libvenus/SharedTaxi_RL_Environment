# =============================================================================
# Lenovo D365 Sales AI — Docker Compose environment
# Copy to .env and fill in real values. Never commit .env to git.
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL (shared instance)
# ---------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# Host port to expose Postgres on (useful for local DB tools like DBeaver/TablePlus).
# The services connect internally via Docker networking — this port is NOT used
# by the app itself, only for external access. Set to 0 or remove the ports:
# entry in docker-compose.yml entirely if you don't need external DB access.
POSTGRES_EXTERNAL_PORT=9432

# ---------------------------------------------------------------------------
# Lenovo-Backend (D365 CRM layer — port 9100)
# ---------------------------------------------------------------------------
# Optional: 'require' for managed cloud Postgres (Azure / RDS / Supabase)
DATABASE_SSLMODE=

# Comma-separated allowed CORS origins
CORS_ORIGINS=http://localhost,http://localhost:9080

# Month the fiscal year starts (1=Jan, 4=Apr). Default 4.
FISCAL_YEAR_START_MONTH=4

# ---------------------------------------------------------------------------
# Lenovo-AIBackend (meeting intelligence — port 9101)
# ---------------------------------------------------------------------------
SYSTEM_EMAIL_ADDRESS=sales-assistant@lenovo.com
CONSENT_WINDOW_MINUTES=60
INTERNAL_EMAIL_DOMAINS=lenovo.com,motorola.com
CONSENT_RETRY_DELAY_MINUTES=10

DATA_TASK_STALE_DAYS=30
DATA_TASK_SCAN_PAGE_SIZE=100
DATA_TASK_DEFAULT_SEVERITY=medium

D365_TIMEOUT_SECONDS=5.0

# Public-facing URL of the AIBackend — used as Vexa webhook callback and
# consent opt-out links. Must be reachable by external services in production.
PUBLIC_AIBACKEND_URL=http://localhost:9101

# Microsoft Graph API credentials (Teams meeting creation)
TENANT_ID=
CLIENT_ID=
CLIENT_SECRET=
GRAPH_VERIFY_SSL=true

# Service account UPN that owns calendar invites (AIBackend)
AIBACKEND_USER_ID=SVC_Lenovo_D365_PoC@yourdomain.com

# ---------------------------------------------------------------------------
# Vexa bot
# ---------------------------------------------------------------------------
VEXA_BOT_URL=http://your-vexa-host:8056
VEXA_API_KEY=

# ---------------------------------------------------------------------------
# LenovoD365-SalesAI (multi-agent orchestrator — port 9091)
# ---------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_MODEL=gpt-4o
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Service account used by the orchestrator for Microsoft Graph calls
ORCHESTRATOR_USER_ID=
ORCHESTRATOR_USER_EMAIL=

# Default recipient for AI-drafted emails
RECIPIENT_EMAIL=

# ---------------------------------------------------------------------------
# Frontend (Nginx — port 9080)
# ---------------------------------------------------------------------------
FRONTEND_PORT=9080
