# --- PostgreSQL connection ---------------------------------------------------
# Option A (recommended): discrete components. The SQLAlchemy URL is assembled
# automatically. Special characters in the password are URL-encoded for you.
DATABASE_HOST=
DATABASE_PORT=5432
DATABASE_NAME=
DATABASE_USERNAME=
DATABASE_PASSWORD=
# Optional — set to 'require' for managed Postgres (RDS / Supabase / Azure / Neon).
DATABASE_SSLMODE=

# Option B (fallback): a single SQLAlchemy URL. Used only when the discrete
# variables above are blank.
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/lenovo_nitro

# --- CORS --------------------------------------------------------------------
# Comma-separated list of allowed origins for the front-end.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Fiscal calendar (Quarter Pulse) -------------------------------------------
# Month when the fiscal year starts (1=Jan, 4=Apr). Default 4.
# FISCAL_YEAR_START_MONTH=4
