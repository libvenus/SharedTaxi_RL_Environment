# =============================================================================
# Lenovo AI Backend — example env configuration
# =============================================================================
# Copy to `.env` and fill in real values. Never commit `.env` to git.
# =============================================================================

# ---------------------------------------------------------------------------
# Postgres connection (used by Lenovo-AIBackend itself)
# ---------------------------------------------------------------------------
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lenovo_aibackend
# Or override with a single-string DATABASE_URL:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lenovo_aibackend


# ---------------------------------------------------------------------------
# Sprint 1A · US01 — D365 Sales backend integration
# ---------------------------------------------------------------------------
D365_BASE_URL=http://localhost:9100
D365_TIMEOUT_SECONDS=5.0


# ---------------------------------------------------------------------------
# Sprint 1A · US03 — Pre-meeting consent email pipeline
# ---------------------------------------------------------------------------
CONSENT_WINDOW_MINUTES=60
INTERNAL_EMAIL_DOMAINS=lenovo.com,motorola.com
OPT_OUT_BASE_URL=http://localhost:9101

# All AIBackend HTTP routes are mounted under this prefix (D365 uses /api/).
AIBACKEND_API_PREFIX=/ai-api
SYSTEM_EMAIL_ADDRESS=sales-assistant@lenovo.com
CONSENT_RETRY_DELAY_MINUTES=10


# ---------------------------------------------------------------------------
# Sprint 1A · US04 — Data Hygiene daily-scan tuning
# ---------------------------------------------------------------------------

# An opp with NO activity logged for more than this many days triggers
# a 'stale_activity' data-task. Detector escalates to 'high' severity
# at 2x this threshold.
DATA_TASK_STALE_DAYS=30

# How many opps the daily scan loads from D365 per page when paginating
# GET /api/opportunities. 100 = ~3 round-trips for a 300-deal portfolio.
DATA_TASK_SCAN_PAGE_SIZE=100

# Default severity assigned to a task when the source doesn't specify
# one. Detectors override this per-rule; AI-team transcript signals MAY
# override per signal.
DATA_TASK_DEFAULT_SEVERITY=medium
