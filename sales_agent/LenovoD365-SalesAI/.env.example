# Copy this file to ".env" in the project root and fill in real values.
# Loaded by agents/_shared.py, scheduler graph tool, and the API layer.

# ----- Azure OpenAI (LLM) -----
AZURE_AI_FOUNDRY_PROJECT_ENDPOINT=https://<your-resource>.services.ai.azure.com/api/projects/<project>
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_COGNITIVE_SERVICES_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/
AZURE_OPENAI_MODEL=gpt-5
AZURE_OPENAI_DEPLOYMENT=gpt-5
AZURE_OPENAI_API_KEY=<your-azure-openai-api-key>
# Optional — code defaults to 2024-12-01-preview when unset
# AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Optional convenience aliases used by some scripts
API_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/openai/deployments/gpt-5/chat/completions?api-version=2025-01-01-preview
MODEL=gpt-5

# ----- Microsoft Graph API (Teams meeting scheduling) -----
TENANT_ID=<your-tenant-id>
CLIENT_ID=<your-app-client-id>
CLIENT_SECRET=<your-app-client-secret>
USER_EMAIL=<service-account-upn>
USER_ID=<service-account-object-id>
RECIPIENT_EMAIL=<default-recipient-email>
GRAPH_VERIFY_SSL=false

