{
  "info": {
    "_postman_id": "us-som-interview-setup-2026-10",
    "name": "Lenovo — SOM Interview-First Setup (US 3.2.1)",
    "description": "Sales Operating Model · Interview-First Setup.\n\nPrereqs:\n1. Run sql/2026_10_som_interview_setup.sql\n2. uvicorn app.main:app --reload --port 8000\n\nRun folders in order.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "d365BaseUrl", "value": "http://localhost:8000", "type": "string" },
    { "key": "role", "value": "national_manager", "type": "string" },
    { "key": "questionId", "value": "11111111-1111-4111-8111-111111111101", "type": "string" }
  ],
  "item": [
    {
      "name": "01 · Load interview setup",
      "request": {
        "method": "GET",
        "url": "{{d365BaseUrl}}/api/sales-operating-model/interview-setup?role={{role}}"
      }
    },
    {
      "name": "02 · Save draft",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-User-Id", "value": "admin@lenovo.com" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"responses\": [\n    {\n      \"questionId\": \"{{questionId}}\",\n      \"text\": \"Growth with margin discipline this quarter.\"\n    }\n  ]\n}"
        },
        "url": "{{d365BaseUrl}}/api/sales-operating-model/interview-setup/{{role}}/draft"
      }
    },
    {
      "name": "03 · Verify & Save",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-User-Id", "value": "admin@lenovo.com" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"responses\": [\n    {\n      \"questionId\": \"11111111-1111-4111-8111-111111111101\",\n      \"text\": \"Success beyond quota means strategic pipeline and customer outcomes.\"\n    },\n    {\n      \"questionId\": \"11111111-1111-4111-8111-111111111102\",\n      \"text\": \"Optimize for controlled growth.\"\n    }\n  ]\n}"
        },
        "url": "{{d365BaseUrl}}/api/sales-operating-model/interview-setup/{{role}}/save"
      }
    },
    {
      "name": "04 · Intent cards",
      "request": {
        "method": "GET",
        "url": "{{d365BaseUrl}}/api/sales-operating-model/intent-cards"
      }
    },
    {
      "name": "05 · Context Lake (AI)",
      "request": {
        "method": "GET",
        "url": "{{d365BaseUrl}}/api/sales-operating-model/context-lake"
      }
    },
    {
      "name": "06 · List interview questions",
      "request": {
        "method": "GET",
        "url": "{{d365BaseUrl}}/api/sales-operating-model/interview-questions?role={{role}}"
      }
    }
  ]
}
